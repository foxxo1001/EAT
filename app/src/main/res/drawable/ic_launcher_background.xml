<?xml version="1.0" encoding="utf-8"?>
<!-- 启动图标背景层 —— iOS 灰白渐变，与 App 主背景 #F5F5F7→#E8E8EA 一致
     全 bleed 矩形填充，适配各机型 adaptive-icon 蒙版裁切 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0" android:color="#FFF5F5F7"/>
                <item android:offset="1" android:color="#FFE8E8EA"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
